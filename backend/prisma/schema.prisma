generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum RoleKey {
  SUPERADMIN
  GYM_ADMIN
  SALES_RECEPTION
  TRAINER
}

enum LeadStatus {
  OPEN
  CONVERTED
  LOST
}

enum LeadSource {
  WALK_IN
  WEBSITE
  PHONE
  SOCIAL_MEDIA
  REFERRAL
  OTHER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  AT_RISK
  CANCELLED
  PAYMENT_PENDING
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum ClassSessionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum ReservationStatus {
  RESERVED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum CheckInMethod {
  MANUAL
  QR
}

enum TaskType {
  SALES
  RETENTION
  PAYMENT
  OPERATIONAL
  OTHER
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum CommunicationChannel {
  PHONE
  EMAIL
  WHATSAPP
  IN_PERSON
  OTHER
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
  INTERNAL_NOTE
}

enum RiskAlertType {
  PAYMENT_PENDING
  MEMBERSHIP_EXPIRED
  INACTIVE_MEMBER
  LEAD_WITHOUT_FOLLOW_UP
  OVERDUE_TASK
  HIGH_CLASS_OCCUPANCY
}

enum RiskAlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RiskAlertStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  email     String?
  phone     String?
  address   String?
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users             User[]
  pipelineStages    PipelineStage[]
  leads             Lead[]
  members           Member[]
  membershipPlans   MembershipPlan[]
  subscriptions     Subscription[]
  payments          Payment[]
  classTypes        ClassType[]
  classSessions     ClassSession[]
  reservations      Reservation[]
  checkIns          CheckIn[]
  tasks             Task[]
  communicationLogs CommunicationLog[]
  riskAlerts        RiskAlert[]
  auditLogs         AuditLog[]

  @@map("tenants")
}

model User {
  id           String     @id @default(cuid())
  tenantId     String?    @map("tenant_id")
  roleId       String     @map("role_id")
  name         String
  email        String
  passwordHash String     @map("password_hash")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role              Role               @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedLeads     Lead[]             @relation("LeadAssignedUser")
  trainerSessions   ClassSession[]     @relation("ClassSessionTrainer")
  assignedTasks     Task[]             @relation("TaskAssignedUser")
  createdCheckIns   CheckIn[]          @relation("CheckInCreatedBy")
  communicationLogs CommunicationLog[]
  auditLogs         AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([roleId])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String
  key         RoleKey  @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model Lead {
  id              String     @id @default(cuid())
  tenantId        String     @map("tenant_id")
  pipelineStageId String     @map("pipeline_stage_id")
  assignedUserId  String?    @map("assigned_user_id")
  firstName       String     @map("first_name")
  lastName        String?    @map("last_name")
  email           String?
  phone           String?
  source          LeadSource @default(OTHER)
  interest        String?
  status          LeadStatus @default(OPEN)
  lostReason      String?    @map("lost_reason")
  nextActionAt    DateTime?  @map("next_action_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pipelineStage     PipelineStage      @relation(fields: [pipelineStageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedUser      User?              @relation("LeadAssignedUser", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members           Member[]
  tasks             Task[]
  communicationLogs CommunicationLog[]
  riskAlerts        RiskAlert[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, pipelineStageId])
  @@index([assignedUserId])
  @@index([nextActionAt])
  @@map("leads")
}

model PipelineStage {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  key       String
  order     Int
  isFinal   Boolean  @default(false) @map("is_final")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads  Lead[]

  @@unique([tenantId, key])
  @@unique([tenantId, order])
  @@index([tenantId])
  @@map("pipeline_stages")
}

model Member {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  leadId      String?      @map("lead_id")
  firstName   String       @map("first_name")
  lastName    String?      @map("last_name")
  email       String?
  phone       String?
  birthDate   DateTime?    @map("birth_date")
  status      MemberStatus @default(ACTIVE)
  joinedAt    DateTime     @default(now()) @map("joined_at")
  cancelledAt DateTime?    @map("cancelled_at")
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lead              Lead?              @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions     Subscription[]
  payments          Payment[]
  reservations      Reservation[]
  checkIns          CheckIn[]
  tasks             Task[]
  communicationLogs CommunicationLog[]
  riskAlerts        RiskAlert[]

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@map("members")
}

model MembershipPlan {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  name          String
  description   String?
  price         Decimal       @db.Decimal(10, 2)
  billingPeriod BillingPeriod @default(MONTHLY) @map("billing_period")
  durationDays  Int?          @map("duration_days")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions Subscription[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("membership_plans")
}

model Subscription {
  id               String             @id @default(cuid())
  tenantId         String             @map("tenant_id")
  memberId         String             @map("member_id")
  membershipPlanId String             @map("membership_plan_id")
  status           SubscriptionStatus @default(PENDING)
  startDate        DateTime           @map("start_date")
  endDate          DateTime?          @map("end_date")
  cancelledAt      DateTime?          @map("cancelled_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member         Member         @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments       Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, memberId])
  @@index([tenantId, endDate])
  @@index([membershipPlanId])
  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(cuid())
  tenantId       String        @map("tenant_id")
  memberId       String        @map("member_id")
  subscriptionId String?       @map("subscription_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("EUR")
  paymentMethod  PaymentMethod @default(OTHER) @map("payment_method")
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?     @map("paid_at")
  dueDate        DateTime?     @map("due_date")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member       Member        @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, memberId])
  @@index([subscriptionId])
  @@map("payments")
}

model ClassType {
  id                     String   @id @default(cuid())
  tenantId               String   @map("tenant_id")
  name                   String
  description            String?
  defaultDurationMinutes Int?     @map("default_duration_minutes")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classSessions ClassSession[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("class_types")
}

model ClassSession {
  id            String             @id @default(cuid())
  tenantId      String             @map("tenant_id")
  classTypeId   String             @map("class_type_id")
  trainerUserId String?            @map("trainer_user_id")
  startsAt      DateTime           @map("starts_at")
  endsAt        DateTime?          @map("ends_at")
  capacity      Int
  status        ClassSessionStatus @default(SCHEDULED)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classType    ClassType     @relation(fields: [classTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trainer      User?         @relation("ClassSessionTrainer", fields: [trainerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservations Reservation[]
  checkIns     CheckIn[]

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@index([tenantId, status])
  @@index([classTypeId])
  @@index([trainerUserId])
  @@map("class_sessions")
}

model Reservation {
  id             String            @id @default(cuid())
  tenantId       String            @map("tenant_id")
  memberId       String            @map("member_id")
  classSessionId String            @map("class_session_id")
  status         ReservationStatus @default(RESERVED)
  reservedAt     DateTime          @default(now()) @map("reserved_at")
  cancelledAt    DateTime?         @map("cancelled_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checkIn      CheckIn?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, memberId])
  @@index([tenantId, classSessionId])
  @@map("reservations")
}

model CheckIn {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  memberId        String        @map("member_id")
  classSessionId  String?       @map("class_session_id")
  reservationId   String?       @unique @map("reservation_id")
  method          CheckInMethod @default(MANUAL)
  checkedInAt     DateTime      @default(now()) @map("checked_in_at")
  createdByUserId String?       @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member        Member        @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classSession  ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservation   Reservation?  @relation(fields: [reservationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdByUser User?         @relation("CheckInCreatedBy", fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, checkedInAt])
  @@index([tenantId, memberId])
  @@index([tenantId, classSessionId])
  @@index([createdByUserId])
  @@map("check_ins")
}

model Task {
  id             String        @id @default(cuid())
  tenantId       String        @map("tenant_id")
  assignedUserId String?       @map("assigned_user_id")
  leadId         String?       @map("lead_id")
  memberId       String?       @map("member_id")
  title          String
  description    String?
  type           TaskType      @default(OTHER)
  status         TaskStatus    @default(PENDING)
  dueAt          DateTime?     @map("due_at")
  completedAt    DateTime?     @map("completed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedUser User?       @relation("TaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member       Member?     @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  riskAlerts   RiskAlert[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@index([tenantId, leadId])
  @@index([tenantId, memberId])
  @@index([assignedUserId])
  @@map("tasks")
}

model CommunicationLog {
  id         String                 @id @default(cuid())
  tenantId   String                 @map("tenant_id")
  leadId     String?                @map("lead_id")
  memberId   String?                @map("member_id")
  userId     String                 @map("user_id")
  channel    CommunicationChannel   @default(OTHER)
  direction  CommunicationDirection @default(INTERNAL_NOTE)
  summary    String                 @db.Text
  occurredAt DateTime               @default(now()) @map("occurred_at")
  createdAt  DateTime               @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member Member? @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user   User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, occurredAt])
  @@index([tenantId, leadId])
  @@index([tenantId, memberId])
  @@index([userId])
  @@map("communication_logs")
}

model RiskAlert {
  id         String            @id @default(cuid())
  tenantId   String            @map("tenant_id")
  memberId   String?           @map("member_id")
  leadId     String?           @map("lead_id")
  taskId     String?           @map("task_id")
  type       RiskAlertType
  severity   RiskAlertSeverity @default(MEDIUM)
  status     RiskAlertStatus   @default(OPEN)
  message    String
  detectedAt DateTime          @default(now()) @map("detected_at")
  resolvedAt DateTime?         @map("resolved_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member Member? @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, detectedAt])
  @@index([tenantId, memberId])
  @@index([tenantId, leadId])
  @@index([taskId])
  @@map("risk_alerts")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user   User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
