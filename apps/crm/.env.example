APP_NAME="Membora CRM"
APP_ENV="production"
APP_URL="https://app.crm.josehurtado.dev"
WEB_APP_URL="https://app.web.josehurtado.dev"
# Si la web publica responde tambien en otros dominios, separalos por comas:
# WEB_APP_URL="https://app.web.josehurtado.dev,https://tudominio.com,https://www.tudominio.com"
APP_STRICT_POST_ORIGIN="false"

DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="membora_crm"
DB_USERNAME="usuario"
DB_PASSWORD="password"

# Correo de confirmacion para solicitudes recibidas desde la web publica.
# En Plesk conviene usar una cuenta real del dominio.
MAIL_ENABLED="true"
MAIL_MAILER="smtp"
MAIL_FROM_EMAIL="no-reply@josehurtado.dev"
MAIL_FROM_NAME="Membora CRM"
MAIL_REPLY_TO="contacto@josehurtado.dev"

SMTP_HOST="mail.josehurtado.dev"
SMTP_PORT="587"
SMTP_ENCRYPTION="tls"
SMTP_USERNAME="no-reply@josehurtado.dev"
SMTP_PASSWORD="password_de_la_cuenta_de_correo"

# Alternativa si prefieres una sola variable:
# DATABASE_URL="mysql://usuario:password@localhost:3306/membora_crm"
