APP_NAME="Membora CRM"
APP_ENV="production"
APP_URL="https://membora.es/app"
WEB_APP_URL="https://membora.es,https://www.membora.es"
# Opcionales de infraestructura. Mantener comentadas con el despliegue estandar:
# MEMBORA_APP_PATH="/app"
# MEMBORA_PUBLIC_ORIGIN="https://membora.es"
# APP_WEB_URL="https://membora.es,https://www.membora.es"
# Si la web publica responde tambien en otros dominios, separalos por comas:
# WEB_APP_URL="https://membora.es,https://www.membora.es"
APP_STRICT_POST_ORIGIN="true"
# Nombre exclusivo para evitar colisiones con otras aplicaciones PHP del dominio.
SESSION_COOKIE_NAME="MEMBORA_CRM_SESSION"
APP_KEY=""
PLATFORM_ADMIN_PASSWORD=""
DEMO_CLIENT_PASSWORD=""

DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="membora_crm"
DB_USERNAME="usuario"
DB_PASSWORD="password"

# Correo de confirmacion para solicitudes recibidas desde la web publica.
# En Plesk conviene usar una cuenta real del dominio.
MAIL_ENABLED="true"
MAIL_MAILER="smtp"
MAIL_NATIVE_FALLBACK="true"
MAIL_FROM_EMAIL="no-reply@josehurtado.dev"
MAIL_FROM_NAME="Membora CRM"
MAIL_REPLY_TO="contacto@josehurtado.dev"

# Datos fiscales del emisor de facturas SaaS de Membora.
INVOICE_ISSUER_NAME="Membora CRM"
INVOICE_ISSUER_TAX_ID=""
INVOICE_ISSUER_ADDRESS=""
INVOICE_ISSUER_POSTAL_CODE=""
INVOICE_ISSUER_CITY=""
INVOICE_ISSUER_PROVINCE=""
INVOICE_ISSUER_COUNTRY="Espana"
INVOICE_ISSUER_EMAIL="contacto@josehurtado.dev"
INVOICE_ISSUER_PHONE=""

SMTP_HOST="mail.josehurtado.dev"
SMTP_PORT="587"
SMTP_ENCRYPTION="tls"
SMTP_USERNAME="no-reply@josehurtado.dev"
SMTP_PASSWORD="password_de_la_cuenta_de_correo"

# Stripe Billing para cobros SaaS de Membora a gimnasios.
# Usar solo claves de test durante desarrollo.
PAYMENTS_MODE="stripe_test"
STRIPE_PUBLISHABLE_KEY="pk_test_PEGAR_AQUI"
STRIPE_SECRET_KEY="sk_test_PEGAR_AQUI"
STRIPE_WEBHOOK_SECRET="whsec_PEGAR_AQUI"
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# Alternativa si prefieres una sola variable:
# DATABASE_URL="mysql://usuario:password@localhost:3306/membora_crm"
