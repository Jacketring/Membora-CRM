# Dependencies
node_modules/
/apps/crm/vendor/
/vendor/
/apps/crm/coverage/
/apps/crm/.phpunit.cache/
/e2e/test-results/
/e2e/playwright-report/

# Environment files (secretos fuera del repo, en cualquier nivel)
.env
.env.*
!.env.example

# Build outputs
dist/
build/
.next/
out/

# Almacenamiento en tiempo de ejecucion (se conservan las carpetas via .gitkeep)
apps/crm/public/uploads/*
!apps/crm/public/uploads/.gitkeep
!apps/crm/public/uploads/.htaccess
shared/storage/*
!shared/storage/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor
.DS_Store
Thumbs.db
.vscode/
.idea/
